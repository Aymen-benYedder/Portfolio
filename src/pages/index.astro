---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroCard from '@components/sections/HeroCard.astro';
import WorkCard from '@components/sections/WorkCard.astro';
import ProjectCard from '@components/sections/ProjectCard.astro';
import SkillCategory from '@components/sections/SkillCategory.astro';
import FAQAccordion from '@components/islands/FAQAccordion.tsx';
import DeployMeta from '@components/ui/DeployMeta.astro';
import FAQPageSchema from '@components/seo/FAQPageSchema.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { fetchSanityApi } from '@lib/sanity';

let siteSettings = null;
let experiences = [];
let projects = [];
let skills = [];
let faqs = [];
let education = [];

try {
  const siteData = await fetchSanityApi('*[_type == "siteSettings"][0]');
  siteSettings = siteData.result;
} catch (e) { console.warn('No site settings'); }

try {
  const expData = await fetchSanityApi('*[_type == "experience"] | order(order asc)');
  experiences = expData.result || [];
} catch (e) { console.warn('No experiences'); }

try {
  const projData = await fetchSanityApi('*[_type == "project"] | order(order asc)');
  projects = projData.result || [];
} catch (e) { console.warn('No projects'); }

try {
  const skillData = await fetchSanityApi('*[_type == "skill"] | order(order asc)');
  skills = skillData.result || [];
} catch (e) { console.warn('No skills'); }

try {
  const faqData = await fetchSanityApi('*[_type == "faq"] | order(order asc)');
  faqs = faqData.result || [];
} catch (e) { console.warn('No faqs'); }

try {
  const eduData = await fetchSanityApi('*[_type == "education"] | order(order asc)');
  education = eduData.result || [];
} catch (e) { console.warn('No education'); }

---

<BaseLayout
  title="Aymen ben Yedder — DevOps & Cloud Infrastructure Engineer"
  description="Expert DevOps engineer specializing in Kubernetes, Terraform, GitOps, and cloud infrastructure. Available for remote contracts globally."
  canonical="https://aymen.benyedder.top/"
  ogType="profile"
>
  <BreadcrumbSchema items={[{ name: 'Home', url: 'https://aymen.benyedder.top/' }]} />
  {faqs?.length > 0 && <FAQPageSchema items={faqs.map((f: any) => ({ question: f.question, answer: f.answer }))} />}

  <!-- Hero Section -->
  <HeroCard />

  <!-- Services Section -->
  <section id="services" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">Services</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">Expert Solutions for Modern Development</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-gap-lg)] items-start">
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <div class="service-icon text-[var(--accent)] shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
              <path d="M21 3v5h-5" />
              <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
              <path d="M3 21v-5h5" />
            </svg>
          </div>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">WordPress Development</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">Professional WordPress development including custom themes, plugins, WooCommerce, and performance optimization.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Custom Theme Development</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Plugin Development</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ WooCommerce Integration</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Performance Optimization</li>
              </ul>
              <a href="/services/wordpress-development" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block underline" aria-label="Learn more about WordPress development services">Learn More →</a>
            </div>
          </div>
        </div>
      </details>
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <div class="service-icon text-[var(--accent)] shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="1" />
              <circle cx="19" cy="12" r="1" />
              <circle cx="5" cy="12" r="1" />
              <path d="M12 5v14" />
              <path d="M5 5l14 14" />
              <path d="M5 19l14-14" />
            </svg>
          </div>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">MERN Stack Development</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">Scalable, high-performance web applications with React, Node.js, MongoDB, and Express.js.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Full-Stack JavaScript</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ React Development</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Node.js & Express</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ MongoDB Integration</li>
              </ul>
              <a href="/services/mern-development" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block underline" aria-label="Learn more about MERN stack development services">Learn More →</a>
            </div>
          </div>
        </div>
      </details>
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <div class="service-icon text-[var(--accent)] shrink-0" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
              <line x1="2" y1="11" x2="22" y2="11" />
            </svg>
          </div>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">Production Server Setup & CI/CD</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">Secure VPS configuration, NGINX, PM2, SSL certificates, and automated GitHub Actions deployment pipelines.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Secure VPS Configuration</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ NGINX & PM2 Setup</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ GitHub Actions Automation</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ SSL/TLS Certificates</li>
              </ul>
              <a href="/#contact" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block no-underline hover:underline">Get Started →</a>
            </div>
          </div>
        </div>
      </details>
    </div>
  </section>

  <!-- Latest Writing -->
  <section id="insights" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">Latest Writing</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">DevOps, infrastructure, and site reliability engineering</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-gap-lg)] items-start">
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">Technical Blog Archive</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">Use the primary blog landing page to reach every live post on DevOps, AI workflow orchestration, observability, and production resilience.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Primary blog landing page</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Links to every live article</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Clean crawl path from the homepage</li>
              </ul>
              <a href="/blog/" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block no-underline hover:underline">Open the blog archive →</a>
            </div>
          </div>
        </div>
      </details>
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">Multi-Cloud Resilience Guide</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">A featured article on OpenTofu, Terragrunt, and provider-neutral infrastructure patterns for reliable delivery at scale.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ OpenTofu and Terragrunt</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Portable infrastructure patterns</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Architecture-level reliability</li>
              </ul>
              <a href="/blog/architecting-multi-cloud-resilience-opentofu-terragrunt-mandatory-2026/" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block no-underline hover:underline">Read the resilience article →</a>
            </div>
          </div>
        </div>
      </details>
      <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0">
        <summary class="collapsible-trigger">
          <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)]">CI/CD Breach Analysis</span>
        </summary>
        <div class="collapsible-reveal">
          <div class="collapsible-reveal-inner">
            <div class="pb-[var(--card-py)]">
              <p class="text-[var(--text-small)] text-[var(--text-2)]">A direct link into the Hackerbot-Claw post covering trust-boundary failures, supply-chain risk, and practical DevSecOps hardening moves.</p>
              <ul class="list-none p-0 mt-[var(--spacing-gap-sm)] space-y-[4px]">
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Supply-chain security review</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ CI/CD trust boundary analysis</li>
                <li class="text-[var(--text-xs)] text-[var(--text-3)] font-[family-name:var(--font-mono)]">→ Hardening actions for teams</li>
              </ul>
              <a href="/blog/execution-layer-breach-hackerbot-claw-cicd-compromise/" class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--accent)] mt-[var(--spacing-gap-sm)] inline-block no-underline hover:underline">Read the breach analysis →</a>
            </div>
          </div>
        </div>
      </details>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">About</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">Engineering lead who ships</h2>
    </div>
    <div class="glass-panel px-[var(--card-px)] py-[var(--card-py)] terminal-corner">
      <h3 class="font-[family-name:var(--font-mono)] text-[var(--text-base)] font-bold text-[var(--text-1)] mb-[var(--spacing-gap-md)]">I bridge complex infrastructure with a calm, reliable product experience.</h3>
      <p class="text-[var(--text-base)] text-[var(--text-2)] leading-relaxed mb-[var(--spacing-gap-lg)]">I reduce system friction, align teams, and remove noise from your delivery pipeline so your product stays stable at scale.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--spacing-gap-lg)]">
        <div>
          <h4 class="label-caps text-[var(--accent)] mb-[var(--spacing-gap-sm)]">The Result</h4>
          <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">Production systems stay up. Teams move faster. Leadership has clarity on delivery timelines and infrastructure health.</p>
        </div>
        <div>
          <h4 class="label-caps text-[var(--accent)] mb-[var(--spacing-gap-sm)]">The Approach</h4>
          <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">I audit existing systems, identify friction points, and build automation that reduces manual toil. Then I document and train teams.</p>
        </div>
      </div>
      <div class="mt-[var(--spacing-gap-md)]">
        <h4 class="label-caps text-[var(--accent)] mb-[var(--spacing-gap-sm)]">The Promise</h4>
        <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">Your infrastructure becomes an asset, not a liability. Deployments are calm. Incidents are rare. Your team can focus on building.</p>
      </div>
      <div class="flex flex-wrap gap-[var(--spacing-gap-xs)] mt-[var(--spacing-gap-md)]">
        <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] px-[8px] py-[3px] border border-[var(--border)] text-[var(--text-2)]">DevOps orchestration</span>
        <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] px-[8px] py-[3px] border border-[var(--border)] text-[var(--text-2)]">Project leadership</span>
        <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] px-[8px] py-[3px] border border-[var(--border)] text-[var(--text-2)]">Release reliability</span>
        <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] px-[8px] py-[3px] border border-[var(--border)] text-[var(--text-2)]">System automation</span>
      </div>
    </div>
  </section>

  <!-- Work Experience -->
  <section id="experience" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">Experience</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">Execution that survives production</h2>
    </div>
    <div class="timeline-track">
      {experiences?.length > 0 ? experiences.map((exp: any) => (
        <WorkCard
          company={exp.company}
          location={exp.location}
          period={exp.period}
          role={exp.role}
          description={exp.description}
          highlight={exp.highlight}
          skills={exp.skills || []}
          collapsible={true}
        />
      )) : (
        <>
          <WorkCard company="Alizeth" location="Medenine" period="Mar 2023 - Present" role="DevOps Engineer & Project Manager" description="Handling project management and DevOps with a focus on infrastructure automation, deployments, and scalable architecture." highlight="Overseeing automation, deployments, and infrastructure" skills={['Infrastructure', 'DevOps', 'Project Management']} collapsible={true} />
          <WorkCard company="DevCom" location="Medenine" period="Mar 2021 - Feb 2023" role="Tech Support" description="Provided technical support and troubleshooting to ensure system reliability and resolve critical issues efficiently." highlight="Ensuring system reliability and uptime" skills={['Technical Support', 'System Reliability', 'Troubleshooting']} collapsible={true} />
          <WorkCard company="CB Audit & Conseil" location="Tunis" period="Oct 2016 - Oct 2020" role="IT Technician" description="Provided IT support with focus on maintaining hardware, software, and network systems." highlight="Maintained hardware, software, and network systems" skills={['IT Support', 'System Maintenance', 'Networking']} collapsible={true} />
        </>
      )}
    </div>
    <DeployMeta hash="sha: a3f7bc2" date="2025-01-15T14:32:07Z" branch="main" message="feat: add work experience section" />
  </section>



  <!-- Projects -->
  <section id="projects" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">Selected Work</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">Systems that stay calm under pressure</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-gap-lg)] items-start">
      {projects?.length > 0 ? projects.map((proj: any) => (
        <ProjectCard title={proj.title} badge={proj.badge} description={proj.description} tags={proj.tags || []} link={proj.link} linkText={proj.linkText} meta={proj.meta} collapsible={true} />
      )) : (
        <>
          <ProjectCard title="Eatorder" badge="Food Ordering Platform" description="Food ordering and restaurant management platform. Handled project management and DevOps infrastructure for scalable deployments." tags={['PM', 'DevOps', 'Infrastructure']} link="https://market.eatorder.fr" linkText="View Eatorder project →" meta="Alizeth · Medenine · Ongoing" collapsible={true} />
          <ProjectCard title="Riskvision" badge="Safety Management Platform" description="Safety and risk management platform. Developed full-stack features and managed deployments for production reliability." tags={['Full Stack', 'Deployments', 'DevOps']} link="/#contact" linkText="View Riskvision project →" meta="DevCom · Medenine · Ongoing" collapsible={true} />
          <ProjectCard title="Lavocato" badge="On-Demand Services Platform" description="On-demand services platform. Developed frontend features and managed applications to production." tags={['Frontend', 'Deployments', 'DevOps']} link="/#contact" linkText="View Lavocato project →" meta="CB Audit · Medenine · Ongoing" collapsible={true} />
        </>
      )}
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="max-w-[var(--container-max)] mx-auto px-[var(--section-px)] mt-[var(--section-gap)]">
    <div class="terminal-section-header mb-[var(--spacing-gap-xl)]">
      <span class="label-caps text-[var(--accent)]">Capabilities</span>
      <h2 class="font-[family-name:var(--font-mono)] text-[var(--heading-sm)] font-bold text-[var(--text-1)]">What I bring into your team</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--spacing-gap-lg)] items-start">
      {skills?.length > 0 ? skills.map((skill: any) => (
        <SkillCategory title={skill.title} skills={skill.skills || []} collapsible={true} />
      )) : (
        <>
          <SkillCategory title="Infrastructure & DevOps" skills={['Linux', 'NGINX', 'Apache', 'Docker', 'CI/CD', 'Git', 'GitHub Actions', 'ArgoCD', 'FluxCD', 'PM2']} collapsible={true} />
          <SkillCategory title="Monitoring & Security" skills={['Prometheus', 'Grafana', 'ELK', 'SSL/TLS', 'Fail2Ban']} collapsible={true} />
          <SkillCategory title="Development" skills={['React', 'Node.js', 'JavaScript', 'HTML5', 'CSS3']} collapsible={true} />
          <SkillCategory title="Automation & Scripting" skills={['Bash', 'PowerShell']} collapsible={true} />
          <SkillCategory title="Databases" skills={['MongoDB', 'PostgreSQL', 'MySQL']} collapsible={true} />
          <SkillCategory title="Project Management" skills={['Agile', 'Scrum', 'Kanban', 'ClickUp']} collapsible={true} />
        </>
      )}
    </div>
