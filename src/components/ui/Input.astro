---
export interface Props {
  label?: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
}

const { label = '', type = 'text', placeholder = '', required = false, class: className = '' } = Astro.props;
const id = label.toLowerCase().replace(/\s+/g, '-');
---

<div class="form-group {className}">
  {label && <label for={id} class="font-[family-name:var(--font-mono)] text-[9px] font-bold tracking-[0.12em] text-[var(--text-3)] mb-[6px] block transition-colors duration-80">{label}</label>}
  {type === 'textarea' ? (
    <textarea id={id} name={id} placeholder={placeholder} {required} class="font-[family-name:var(--font-mono)] text-[12px] text-[var(--text-1)] bg-[var(--inset)] border border-[var(--border)] px-[14px] py-[9px] outline-none w-full transition-colors duration-80 focus:border-[var(--accent)]"></textarea>
  ) : type === 'select' ? (
    <select id={id} name={id} {required} class="font-[family-name:var(--font-mono)] text-[12px] text-[var(--text-1)] bg-[var(--inset)] border border-[var(--border)] px-[14px] py-[9px] outline-none w-full transition-colors duration-80 focus:border-[var(--accent)]">
      <slot name="options" />
    </select>
  ) : (
    <input {type} id={id} name={id} placeholder={placeholder} {required} class="font-[family-name:var(--font-mono)] text-[12px] text-[var(--text-1)] bg-[var(--inset)] border border-[var(--border)] px-[14px] py-[9px] outline-none w-full transition-colors duration-80 placeholder:text-[var(--text-3)] focus:border-[var(--accent)]" />
  )}
</div>
