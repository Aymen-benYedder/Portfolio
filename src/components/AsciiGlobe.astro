---
// AsciiGlobe.astro
// Pixel block name — "AYMEN" in emerald / "ben Yedder" in gray.
// Block sizes are computed to fit the container width, then multiplied by blockScale.
// Smaller render font = fewer pixel columns = bigger blocks at the same screen width.

interface Props {
  width?: string;
  height?: string;
  accent?: string;
  gray?: string;
  fontFamily?: string;
  firstFont?: number;       // Offscreen render font size for "AYMEN" (smaller = chunkier blocks)
  baseFont?: number;        // Offscreen render font size for "ben Yedder"
  blockRatio?: number;      // Fraction of container width used for block computation
  blockScale?: number;      // Multiplier on computed block size (1 = fit container, 2 = 2x bigger)
  pixelGap?: number;        // Gap in px between each pixel block (0 = solid)
  rowGapRatio?: number;     // Gap between lines as fraction of first block size
}

const {
  width = "100%",
  height = "auto",
  accent = "#34d399",
  gray = "#6b7280",
  fontFamily = "JetBrains Mono",
  firstFont = 45,
  baseFont = 18,
  blockRatio = 0.88,
  blockScale = 1,
  pixelGap = 1,
  rowGapRatio = 0.6,
} = Astro.props;
---

<div class="ascii-globe-wrap" style={`width: ${width}; ${height !== 'auto' ? `height: ${height};` : ''}`}>
  <canvas id="ascii-globe"
    data-accent={accent}
    data-gray={gray}
    data-font={fontFamily}
    data-first-font={firstFont}
    data-base-font={baseFont}
    data-block-ratio={blockRatio}
    data-block-scale={blockScale}
    data-pixel-gap={pixelGap}
    data-row-gap-ratio={rowGapRatio}
  ></canvas>
</div>

<style>
  .ascii-globe-wrap {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background-color: transparent;
    overflow: hidden;
  }
  #ascii-globe {
    display: block;
    background: transparent;
    image-rendering: pixelated;
  }
</style>

<script>
  function hexToRgba(hex, alpha) {
    const h = hex.replace('#', '');
    return `rgba(${parseInt(h.substring(0,2),16)}, ${parseInt(h.substring(2,4),16)}, ${parseInt(h.substring(4,6),16)}, ${Math.max(0, Math.min(1, alpha))})`;
  }

  // ─── Render text to binary pixel grid ───
  function textToGrid(text, fontSize, fontFam, bold) {
    const ca = document.createElement('canvas');
    const cx = ca.getContext('2d');
    if (!cx) return null;

    const weight = bold ? '800' : '400';
    cx.font = `${weight} ${fontSize}px "${fontFam}", monospace`;
    const m = cx.measureText(text);
    const w = Math.max(1, Math.ceil(m.width) + 4);
    const h = Math.ceil(fontSize * 1.4);

    ca.width = w;
    ca.height = h;
    cx.clearRect(0, 0, w, h);
    cx.font = `${weight} ${fontSize}px "${fontFam}", monospace`;
    cx.fillStyle = '#fff';
    cx.textBaseline = 'top';
    cx.fillText(text, 0, 0);

    const img = cx.getImageData(0, 0, w, h);
    const data = img.data;
    const grid = [];
    for (let y = 0; y < h; y++) {
      const row = [];
      for (let x = 0; x < w; x++) {
        row.push(data[(y * w + x) * 4 + 3] > 40 ? 1 : 0);
      }
      grid.push(row);
    }

    // Trim transparent edges
    let minX = w, maxX = 0, minY = h, maxY = 0;
    for (let y = 0; y < h; y++)
      for (let x = 0; x < w; x++)
        if (grid[y][x]) {
          if (x < minX) minX = x;
          if (x > maxX) maxX = x;
          if (y < minY) minY = y;
          if (y > maxY) maxY = y;
        }
    const trimmed = [];
    for (let y = minY; y <= maxY; y++) {
      const row = [];
      for (let x = minX; x <= maxX; x++) row.push(grid[y][x]);
      trimmed.push(row);
    }
    return { grid: trimmed, cols: maxX - minX + 1, rows: maxY - minY + 1 };
  }

  /* ──────── INIT ──────── */
  function initAsciiGlobe() {
    const canvas = /** @type {HTMLCanvasElement} */ (document.getElementById('ascii-globe'));
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const ACCENT = canvas.dataset.accent || '#34d399';
    const GRAY   = canvas.dataset.gray || '#6b7280';
    const FONT   = canvas.dataset.font || 'JetBrains Mono';
    const FIRST_FONT = parseInt(canvas.dataset.firstFont) || 45;
    const BASE_FONT  = parseInt(canvas.dataset.baseFont) || 18;
    const BLOCK_RATIO = parseFloat(canvas.dataset.blockRatio) || 0.88;
    const BLOCK_SCALE = parseFloat(canvas.dataset.blockScale) || 1;
    const PIXEL_GAP  = parseInt(canvas.dataset.pixelGap) || 1;
    const ROW_GAP_RATIO = parseFloat(canvas.dataset.rowGapRatio) || 0.6;

    let rafId = 0;
    let grid1 = null, grid2 = null;
    let cols1 = 0, rows1 = 0, cols2 = 0, rows2 = 0;
    let width1 = 0, width2 = 0;

    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const prefersReducedMotion = mq.matches;

    // ─── Build pixel grids ───
    function buildGrids() {
      const r1 = textToGrid('AYMEN', FIRST_FONT, FONT, true);
      const r2 = textToGrid('ben Yedder', BASE_FONT, FONT, false);
      if (r1 && r2) {
        grid1 = r1.grid; cols1 = r1.cols; rows1 = r1.rows;
        width1 = r1.cols;
        grid2 = r2.grid; cols2 = r2.cols; rows2 = r2.rows;
        width2 = r2.cols;
        sizeCanvas();
      }
    }

    function buildWithFontCheck() {
      if (document.fonts && document.fonts.ready)
        document.fonts.ready.then(buildGrids);
      else buildGrids();
    }
    buildWithFontCheck();

    // ─── Size canvas from pixel grid × container width ───
    function sizeCanvas() {
      if (!grid1 || !grid2) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);

      // Available width from parent container
      const parent = canvas.parentElement;
      const cssW = parent ? parent.clientWidth : canvas.clientWidth;

      if (cssW <= 0) {
        // Retry after resize
        setTimeout(sizeCanvas, 100);
        return;
      }

      // Compute block sizes from container width
      const baseBs1 = Math.max(1, Math.floor((cssW * BLOCK_RATIO) / cols1));
      const bs1 = Math.max(1, Math.round(baseBs1 * BLOCK_SCALE));
      const fill1 = Math.max(1, bs1 - PIXEL_GAP);

      const fontRatio = BASE_FONT / FIRST_FONT;
      const bs2 = Math.max(1, Math.round(bs1 * fontRatio));
      const fill2 = Math.max(1, bs2 - PIXEL_GAP);

      const totalW1 = cols1 * bs1;
      const totalW2 = cols2 * bs2;
      const canvasW = Math.max(totalW1, totalW2);
      const rowGap = Math.round(bs1 * ROW_GAP_RATIO);
      const canvasH = rows1 * bs1 + rowGap + rows2 * bs2;

      canvas._layout = { bs1, bs2, fill1, fill2, totalW1, totalW2, canvasW, rowGap, canvasH, cssW };

      canvas.width = canvasW * dpr;
      canvas.height = canvasH * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    // ─── Draw a single pixel grid ───
    function drawGrid(g, gCols, gRows, ox, oy, bs, fill, color, t, offset, animate) {
      for (let r = 0; r < gRows; r++) {
        for (let c = 0; c < gCols; c++) {
          if (!g[r][c]) continue;

          let alpha;
          if (!animate || prefersReducedMotion) {
            alpha = 0.92;
          } else {
            // Visible wave oscillation: alpha 0.35–0.95
            const wave = Math.sin(t * 2.2 + c * 0.18 + r * 0.25 + offset) * 0.3 + 0.65;
            // Random flicker for glitch-pixel feel
            const flick = Math.random() < 0.008 ? 0.2 + Math.random() * 0.4 : 1.0;
            alpha = Math.max(0.2, Math.min(1, wave * flick));
          }

          ctx.fillStyle = hexToRgba(color, alpha);
          ctx.fillRect(ox + c * bs, oy + r * bs, fill, fill);
        }
      }
    }

    // ─── Main draw loop ───
    function draw(now) {
      if (!grid1 || !grid2 || !canvas._layout) {
        rafId = requestAnimationFrame(draw);
        return;
      }
      const t = now / 1000;
      ctx.clearRect(0, 0, canvas._layout.canvasW, canvas._layout.canvasH);

      const { bs1, bs2, fill1, fill2, totalW1, totalW2, canvasW, rowGap } = canvas._layout;
      const ox = (canvasW - Math.max(totalW1, totalW2)) / 2;

      // ── AYMEN (emerald, animated wave + flicker) ──
      const ox1 = ox + (Math.max(totalW1, totalW2) - totalW1) / 2;
      drawGrid(grid1, cols1, rows1, ox1, 0, bs1, fill1, ACCENT, t, 0, true);

      // ── ben Yedder (gray, animated wave) ──
      const oy2 = rows1 * bs1 + rowGap;
      const ox2 = ox + (Math.max(totalW1, totalW2) - totalW2) / 2;
      drawGrid(grid2, cols2, rows2, ox2, oy2, bs2, fill2, GRAY, t, 2.5, true);

      rafId = requestAnimationFrame(draw);
    }

    rafId = requestAnimationFrame(draw);

    // Re-layout on resize (debounced)
    let resizeTimer = 0;
    const ro = new ResizeObserver(() => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => sizeCanvas(), 120);
    });
    ro.observe(canvas.parentElement);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      ro.disconnect();
    }, { once: true });
  }

  let _initialised = false;
  function safe() {
    if (_initialised) return;
    _initialised = true;
    try { initAsciiGlobe(); } catch (_) {}
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', safe);
  else safe();
  document.addEventListener('astro:page-load', safe);
</script>
