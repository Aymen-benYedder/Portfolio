---
export interface Props {
  columns?: '2' | '3' | '4' | '32' | '23';
  class?: string;
}

const { columns = '2', class: className = '' } = Astro.props;

const colClasses: Record<string, string> = {
  '2': 'grid-cols-2',
  '3': 'grid-cols-3',
  '4': 'grid-cols-4',
  '32': 'grid-cols-[3fr_2fr]',
  '23': 'grid-cols-[2fr_3fr]',
};
---

<div class="bento grid gap-[1px] bg-[var(--border)] max-md:grid-cols-1 {colClasses[columns]} {className}">
  <slot />
</div>
