---
import Badge from '@components/ui/Badge.astro';

export interface Props {
  title: string;
  badge: string;
  description: string;
  tags: string[];
  link: string;
  linkText?: string;
  meta?: string;
  collapsible?: boolean;
  class?: string;
}
const { title, badge: badgeText, description, tags, link, linkText = 'View project →', meta = '', collapsible = false, class: className = '' } = Astro.props;
---

{
  collapsible ? (
    <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0 {className}">
      <summary class="collapsible-trigger">
        <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
        <div class="flex items-center gap-[8px] flex-1 min-w-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)] truncate">{title}</span>
        </div>
        <Badge variant="blue">{badgeText}</Badge>
      </summary>
      <div class="collapsible-reveal">
        <div class="collapsible-reveal-inner">
          <div class="pb-[var(--card-py)]">
            <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">{description}</p>
            {meta && <p class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] mt-[var(--spacing-gap-xs)]">{meta}</p>}
            <div class="flex flex-wrap gap-[var(--spacing-gap-xs)] mt-[var(--spacing-gap-sm)]">
              {tags.map(tag => <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] px-[6px] py-[2px] border border-[var(--border)]">{tag}</span>)}
            </div>
            <a href={link} class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] mt-[var(--spacing-gap-sm)] inline-block no-underline uppercase tracking-[0.1em] transition-all duration-200 hover:text-[var(--accent)] hover:translate-x-[4px]">{linkText}</a>
          </div>
        </div>
      </div>
    </details>
  ) : (
    <article class="card-tilt card glass-hover px-[var(--card-px)] py-[var(--card-py)] interactive-scale {className}">
      <div class="card-tilt-inner">
        <div class="flex items-start justify-between mb-[var(--spacing-gap-sm)]">
          <div class="flex items-center gap-[8px]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            <h3 class="font-[family-name:var(--font-mono)] text-[var(--text-base)] font-bold text-[var(--text-1)] m-0">{title}</h3>
          </div>
          <Badge variant="blue">{badgeText}</Badge>
        </div>
        <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">{description}</p>
        {meta && <p class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] mt-[var(--spacing-gap-xs)]">{meta}</p>}
        <div class="flex flex-wrap gap-[var(--spacing-gap-xs)] mt-[var(--spacing-gap-sm)]">
          {tags.map(tag => <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] px-[6px] py-[2px] border border-[var(--border)]">{tag}</span>)}
        </div>
        <a href={link} class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] text-[var(--text-3)] mt-[var(--spacing-gap-sm)] inline-block no-underline uppercase tracking-[0.1em] transition-all duration-200 hover:text-[var(--accent)] hover:translate-x-[4px]">{linkText}</a>
      </div>
    </article>
  )
}
