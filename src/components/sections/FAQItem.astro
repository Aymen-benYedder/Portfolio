---
export interface Props {
  question: string;
  answer: string;
  class?: string;
}
const { question, answer, class: className = '' } = Astro.props;
---

<div class="border-b border-[var(--border)] last:border-b-0 py-[var(--spacing-gap-md)] {className}">
  <h3 class="font-[family-name:var(--font-mono)] text-[var(--text-small)] font-bold text-[var(--text-1)] mb-[var(--spacing-gap-sm)]">{question}</h3>
  <p class="text-[var(--text-small)] text-[var(--text-2)] leading-relaxed">{answer}</p>
</div>
