---
export interface Props {
  title: string;
  skills: string[];
  collapsible?: boolean;
  class?: string;
}
const { title, skills, collapsible = false, class: className = '' } = Astro.props;
---

{
  collapsible ? (
    <details class="collapsible-section card glass-hover px-[var(--card-px)] py-0 {className}">
      <summary class="collapsible-trigger">
        <svg class="collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
        <div class="flex items-center gap-[8px] flex-1 min-w-0">
          {title.includes('Infrastructure') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
              <line x1="6" y1="6" x2="6.01" y2="6"></line>
              <line x1="6" y1="18" x2="6.01" y2="18"></line>
            </svg>
          )}
          {title.includes('Monitoring') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          )}
          {title.includes('Development') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          )}
          {title.includes('Automation') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <path d="M12 2v4"></path>
              <path d="m19.07 4.93-2.12 2.12"></path>
              <path d="M22 12h-4"></path>
              <path d="m19.07 19.07-2.12-2.12"></path>
              <path d="M12 22v-4"></path>
              <path d="m4.93 19.07 2.12-2.12"></path>
              <path d="M2 12h4"></path>
              <path d="m4.93 4.93 2.12 2.12"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          )}
          {title.includes('Databases') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
              <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
              <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
            </svg>
          )}
          {title.includes('Project Management') && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="3" x2="9" y2="21"></line>
              <line x1="15" y1="3" x2="15" y2="21"></line>
            </svg>
          )}
          <span class="label-caps text-[var(--accent)] truncate">{title}</span>
        </div>
      </summary>
      <div class="collapsible-reveal">
        <div class="collapsible-reveal-inner">
          <div class="flex flex-wrap gap-[var(--spacing-gap-xs)] pb-[var(--card-py)]">
            {skills.map(skill => (
              <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] font-medium tracking-[0.04em] px-[10px] py-[4px] border border-[var(--border)] text-[var(--text-2)] transition-all duration-200 hover:border-[var(--accent)] hover:text-[var(--accent)] hover:bg-[rgba(16,185,129,0.08)] interactive-scale">{skill}</span>
            ))}
          </div>
        </div>
      </div>
    </details>
  ) : (
    <div class="card glass-hover px-[var(--card-px)] py-[var(--card-py)] hover-lift {className}" data-reveal="scale">
      <div class="flex items-center gap-[8px] mb-[var(--spacing-gap-sm)]">
        {title.includes('Infrastructure') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
            <line x1="6" y1="6" x2="6.01" y2="6"></line>
            <line x1="6" y1="18" x2="6.01" y2="18"></line>
          </svg>
        )}
        {title.includes('Monitoring') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        )}
        {title.includes('Development') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        )}
        {title.includes('Automation') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <path d="M12 2v4"></path>
            <path d="m19.07 4.93-2.12 2.12"></path>
            <path d="M22 12h-4"></path>
            <path d="m19.07 19.07-2.12-2.12"></path>
            <path d="M12 22v-4"></path>
            <path d="m4.93 19.07 2.12-2.12"></path>
            <path d="M2 12h4"></path>
            <path d="m4.93 4.93 2.12 2.12"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        )}
        {title.includes('Databases') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
          </svg>
        )}
        {title.includes('Project Management') && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent)] shrink-0">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="9" y1="3" x2="9" y2="21"></line>
            <line x1="15" y1="3" x2="15" y2="21"></line>
          </svg>
        )}
        <h3 class="label-caps text-[var(--accent)]">{title}</h3>
      </div>
      <div class="flex flex-wrap gap-[var(--spacing-gap-xs)]">
        {skills.map(skill => (
          <span class="font-[family-name:var(--font-mono)] text-[var(--text-2xs)] font-medium tracking-[0.04em] px-[10px] py-[4px] border border-[var(--border)] text-[var(--text-2)] transition-all duration-200 hover:border-[var(--accent)] hover:text-[var(--accent)] hover:bg-[rgba(16,185,129,0.08)] interactive-scale">{skill}</span>
        ))}
      </div>
    </div>
  )
}
